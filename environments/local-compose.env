UPDATE_API=https://update-service.test.w3champions.com
REPLAY_API=https://replay-service.test.w3champions.com
# ---- chat-revamp wiring: talk to the LOCAL chat-service on w3c-network-local ----
CHAT_API=http://chat-service-local:80
# wb -> chat internal calls; pair with chat-service INTERNAL_SECRET_WB.
CHAT_INTERNAL_API_SECRET=localdev-wb-to-chat-hmac
# verifies chat -> wb relationship calls; pair with chat-service STATISTIC_SERVICE_RELATIONSHIPS_SECRET.
CHAT_RELATIONSHIPS_API_SECRET=localdev-chat-relationships-secret
# Rewards/Patreon disabled locally (auto-sync off, dummy client creds).
REWARDS_DRIFT_AUTO_SYNC_ENABLED=false
PATREON_CLIENT_ID=localdev
PATREON_CLIENT_SECRET=localdev
PATREON_WEBHOOK_SECRET=localdev
# Cloudflare Turnstile "always passes" public test key (not a secret).
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
