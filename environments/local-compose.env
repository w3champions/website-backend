# Local-dev env for website-backend (statistic-service), loaded by docker-compose.yml (env_file:).
# Every value is a LOCAL-DEV-ONLY placeholder (not a production secret) or a public key.

MONGO_CONNECTION_STRING=mongodb://w3champions:w3champions@mongodb-website-backend-local-compose:27017
ADMIN_SECRET=localdev-admin-secret
# Read-model handlers OFF locally: they consume MatchFinishedEvents we don't produce here and
# can touch shared data. Chat details/relationships/presence don't need them.
START_HANDLERS=false
REWARDS_DRIFT_DETECTION_ENABLED=false
MATCHMAKING_API=http://matchmaking-service-local:25048
IDENTIFICATION_SERVICE_URI=https://identification-service.test.w3champions.com
